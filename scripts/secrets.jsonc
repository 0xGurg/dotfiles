{
	// Bitwarden item name containing API tokens and secrets
	"secrets_item": "dotfiles-secrets",
	// Custom field names to extract from the secrets item above
	// Use {{FIELD_NAME}} in .tmpl files to reference them
	"fields": [
		"SANITY_AUTH_TOKEN",
		"BRAVE_API_KEY",
		"CODEBERG_TOKEN"
	],
	// SSH keys to restore to ~/.ssh/
	// String = bw item name and filename are the same
	// Object = { "bw_item": "name-in-bw", "filename": "name-on-disk" }
	"ssh_keys": [
		"io-mac",
		"aur-bigkis-ci"
	]
}
