.env

# Backup files
*.bak

# Raycast binary exports
.config/raycast/*.rayconfig

# Local/sensitive app data (Linux)
.config/BraveSoftware/
.config/dconf/
.config/pulse/
.config/rclone/

# OpenCode quota data
.config/opencode/opencode-quota/opencode-go.json
.config/opencode/node_modules/

# Sanity CLI config (auto-generated telemetry/auth settings)
.config/sanity/

# Zsh history and cache (at $HOME level)
.zsh_history
.zcompdump*

# Nix build results
result
result-*

# Raycast store extensions (third-party, auto-managed)
.config/raycast/extensions/

# SketchyBar generated app font
.config/sketchybar/sketchybar-app-font/

# macOS
.DS_Store

# OpenCode (generated lockfile + dependencies)
.config/opencode/package-lock.json
.config/opencode/node_modules/

# WireGuard config (contains private keys)
wg0.conf

# fgj (third-party git forge tool — may contain tokens)
.config/fgj/

# Neovim (auto-generated Lua config)
.config/nvim/.luarc.json

# Sayang app (separate repo)
sayang/

# Catch-all: private keys and certs
*.pem
*.key
*.p12

# Node (all nested)
**/node_modules/
**/package-lock.json
