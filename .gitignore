.env

# Sanity CLI auth (contains auth tokens)
.config/sanity/

# Zsh history and cache (at $HOME level)
.zsh_history
.zcompdump*

# Nix build results
result
result-*

# Raycast store extensions (third-party, auto-managed)
.config/raycast/extensions/

# SketchyBar generated app font
.config/sketchybar/sketchybar-app-font/

# macOS
.DS_Store

# Browser profile data (contains cookies, sessions, login data)
.config/BraveSoftware/

# Rclone config (contains OAuth tokens)
.config/rclone/rclone.conf

# PulseAudio auth cookie
.config/pulse/cookie

# Dconf user settings (binary blob, may contain tokens)
.config/dconf/user