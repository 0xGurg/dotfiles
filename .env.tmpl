# OpenCode Go — workspace IDs for quota tracking (primary + secondary accounts)
# Find them at: https://opencode.ai/dashboard → URL contains /workspace/<ID>/
export OPENCODE_GO_WORKSPACE_ID_PRIMARY="{{OPENCODE_GO_WORKSPACE_ID_PRIMARY}}"
export OPENCODE_GO_WORKSPACE_ID_SECONDARY="{{OPENCODE_GO_WORKSPACE_ID_SECONDARY}}"

# OpenCode Go — API keys for provider auth (one per workspace)
# Create at: https://opencode.ai/workspace/<ID>/keys
export OPENCODE_GO_API_KEY_PRIMARY="{{OPENCODE_GO_API_KEY_PRIMARY}}"
export OPENCODE_GO_API_KEY_SECONDARY="{{OPENCODE_GO_API_KEY_SECONDARY}}"

# Brave Search MCP (used by Librarian agent in OpenCode)
# Get one at: https://brave.com/search/api/
export BRAVE_API_KEY="{{BRAVE_API_KEY}}"

# Sanity CMS
export SANITY_AUTH_TOKEN="{{SANITY_AUTH_TOKEN}}"
