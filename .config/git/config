[init]
	defaultBranch = main

[user]
	email = george.luis.pagarigan@gmail.com
	name = George Luis Pagarigan

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[fetch]
	prune = true

[rebase]
	autoStash = true

[rerere]
	enabled = true

[diff]
	algorithm = histogram

[merge]
	conflictstyle = zdiff3

[transfer]
	fsckObjects = true

[fetch]
	fsckObjects = true

[receive]
	fsckObjects = true

[commit]
	gpgsign = true

[gpg]
	format = ssh

[gpg "ssh"]
	defaultKeyCommand = ssh-add -L
