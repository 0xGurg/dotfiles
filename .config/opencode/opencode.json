{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-pro",
  "autoupdate": true,
  "plugin": [
    "@slkiser/opencode-quota",
    "oh-my-opencode-slim"
  ],
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "permission": {
    "codesearch": "allow",
    "websearch": "allow"
  },
  "lsp": true,
  "mcp": {
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=flprqcnfoavejgpgyylj&features=docs%2Caccount%2Cdatabase%2Cdebugging%2Cfunctions%2Cdevelopment%2Cbranching%2Cstorage",
      "enabled": true
    }
  }
}
