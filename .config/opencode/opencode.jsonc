{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "github-copilot/gpt-5-mini",
  "autoupdate": true,
  "default_agent": "zero",
  "enabled_providers": ["github-copilot", "opencode"],
  "agent": {
    "build": {
      "disable": true,
    },
  },
  "permission": {
    "websearch": "allow",
    "codesearch": "allow",
  },
  "provider": {
    "github-copilot": {
      "models": {
        "claude-opus-4.6": {
          "name": "Opus 4.6 (3x Planner)",
        },
        "gpt-5.4": {
          "name": "GPT 5.4 (1x Planner)",
        },
        "gpt-4.1": {
          "name": "GPT 4.1 (0x Planner)",
        },
        "gpt-5.3-codex": {
          "name": "Codex 5.3 (1x Executor)",
        },
        "claude-sonnet-4.6": {
          "name": "Sonnet 4.6 (1x Executor)",
        },
        "gpt-5-mini": {
          "name": "GPT 5 Mini (0x Executor/Ask)",
        },
        "claude-haiku-4.5": {
          "name": "Haiku 4.5 (0.33x Ask)",
        },
      },
    },
    "opencode": {
      "models": {
        "big-pickle": {
          "name": "Big Pickle (0x Executor)",
        },
        "mimo-v2-omni-free": {
          "name": "Mimo Omni (0x Planner)",
        },
        "mimo-v2-pro-free": {
          "name": "Mimo Pro (0x Ask)",
        },
        "minimax-m2.5-free": {
          "name": "MiniMax M2.5 (0x Planner)",
        },
      },
    },
  },
}
