{
	"$schema": "https://opencode.ai/config.json",
	"model": "opencode-go/deepseek-v4-pro",
	"small_model": "opencode-go/deepseek-v4-flash",
	"autoupdate": true,
	"default_agent": "executor",
	"agent": {
		"build": {
			"disable": true,
		},
		"plan": {
			"color": "#957FB8",
		},
	},
	"permission": {
		"websearch": "allow",
		"codesearch": "allow",
  },
	"mcp": {
		"brave-search": {
			"type": "local",
			"command": ["brave-search-mcp-server", "--brave-api-key", "{env:BRAVE_API_KEY}"],
			"enabled": true
		}
	}
}
