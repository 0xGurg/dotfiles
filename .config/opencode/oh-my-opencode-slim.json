  "council": {
    "default_preset": "free-pool",
    "presets": {
      "free-pool": {
        "copilot": { "model": "github-copilot/claude-haiku-4.5" },
        "gpt-mini": { "model": "github-copilot/gpt-5-mini" },
        "zen-flash": { "model": "opencode/deepseek-v4-flash-free" },
        "big-pickle": { "model": "opencode/big-pickle" }
      }
    },
    "timeout": 90000,
    "councillor_execution_mode": "parallel",
    "councillor_retries": 1
  },
  "fallback": {
    "enabled": true,
    "timeoutMs": 60000,
    "retryDelayMs": 500,
    "chains": {
      "orchestrator": ["opencode-go/glm-5.1", "openai/gpt-5.3-codex", "openai/gpt-5.4", "opencode/big-pickle"],
