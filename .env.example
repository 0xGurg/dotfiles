# Secrets — copy to .env and fill in values
# This file is tracked; .env is gitignored
#
# Usage: cp .env.example .env && $EDITOR .env

# OpenCode Go — shared workspace ID for quota tracking
# Find it at: https://opencode.ai/dashboard → URL contains /workspace/<ID>/
OPENCODE_GO_WORKSPACE_ID=""

# Brave Search MCP (used by Librarian agent in OpenCode)
# Get one at: https://brave.com/search/api/
BRAVE_API_KEY=""

# Sanity CMS
SANITY_AUTH_TOKEN=""
