# Stow local ignore file
# When this file exists, it replaces stow's built-in defaults
# See: https://www.gnu.org/software/stow/manual/html_node/Types-And-Syntax-Of-Ignore-Lists.html

# Version control
\.git
\.gitignore
\.gitmodules

# Documentation
^/README.*
^/LICENSE.*
^/COPYING

# Backup files
.+~
\#.*\#

# Template files (rendered by inject-secrets.py, don't stow to $HOME)
\.tmpl$

# Local secrets and generated app state
^/\.env$
^/\.config/fgj/config\.yaml$
^/\.config/opencode/node_modules
^/\.config/opencode/package-lock\.json$
^/\.config/opencode/opencode-quota/opencode-go\.json$

# Scripts directory (keep in repo, don't stow to $HOME)
^/scripts

# macOS-only configs (not stowed on Linux)
Brewfile
^\.config/aerospace/
^\.config/sketchybar/
^\.config/raycast/

# OpenCode generated files
pnpm-lock\.yaml
pnpm-workspace\.yaml

# Backup files
\.bak$

# macOS system files
\.DS_Store
